# =============================================================================
# Edu-Curator — Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================

# === Core LLM ===
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=your_cerebras_api_key_here
EXTRACTION_MODEL=gpt-oss-120b
GENERATION_MODEL=gpt-oss-120b

# === Supabase ===
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key — NEVER sent to the browser. Backend / worker only.
SUPABASE_KEY=your_supabase_service_role_key
# anon/public key — safe for browser clients. REQUIRED (SEC-05).
# Supabase Dashboard → Settings → API → Project API Keys → anon public
SUPABASE_ANON_KEY=your_supabase_anon_key

# === Dashboard Server ===
# Railway sets PORT automatically — do NOT override PORT on Railway.
# For local dev only:
DASHBOARD_PORT=8502
# SEC-01: Keep as 127.0.0.1 for local dev.
# Railway/cloud: the app auto-detects cloud and binds to 0.0.0.0.
DASHBOARD_HOST=127.0.0.1

# AUTH-01: Comma-separated emails allowed to log in.
# Anyone not listed is rejected even with a valid Supabase account.
ALLOWED_EMAILS=you@gmail.com,colleague@example.com

# === In-Process Worker ===
# Set to false if you want to run the curation worker as a separate process.
START_IN_PROCESS_WORKER=true

# === Ingestion ===
# Set to true only if web scraping JS-heavy pages is needed.
# Also uncomment the playwright install line in Dockerfile.
PLAYWRIGHT_ENABLED=false

# === LiteLLM Failover ===
GROQ_API_KEY=your_groq_api_key_here
FALLBACK_MODEL=llama-3.3-70b-versatile
LITELLM_FALLBACK_ENABLED=true

# === Redis Cache (optional but recommended for scale) ===
# On Railway: add a Redis plugin in your project, then copy the Redis URL here.
# SEC-19: In production use format: redis://:STRONG_PASSWORD@host:6379/0
REDIS_URL=redis://localhost:6379/0
LLM_CACHE_ENABLED=false
LLM_CACHE_TTL_SECONDS=86400

# === Langfuse Tracing (optional) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Batch API (optional) ===
USE_BATCH_API=false

# === Alembic (direct PostgreSQL for schema migrations) ===
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================================
# Railway-specific notes
# =============================================================================
# Variables to set in Railway Dashboard → your service → Variables:
#
#   CEREBRAS_API_KEY        (required)
#   SUPABASE_URL            (required)
#   SUPABASE_KEY            (required — service role)
#   SUPABASE_ANON_KEY       (required)
#   ALLOWED_EMAILS          (required)
#   LLM_PROVIDER            cerebras
#   EXTRACTION_MODEL        gpt-oss-120b
#   GENERATION_MODEL        gpt-oss-120b
#   START_IN_PROCESS_WORKER true
#   LITELLM_FALLBACK_ENABLED true
#   GROQ_API_KEY            (if using fallback)
#   REDIS_URL               (copy from Railway Redis plugin if added)
#   LLM_CACHE_ENABLED       true  (if Redis plugin added)
#
# DO NOT set PORT — Railway manages it automatically.
# DO NOT set DASHBOARD_HOST — auto-detected as 0.0.0.0 on Railway.
# =============================================================================
