# === Core LLM ===
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=
EXTRACTION_MODEL=gpt-oss-120b
GENERATION_MODEL=gpt-oss-120b

# === Supabase ===
SUPABASE_URL=
# service_role key — NEVER sent to the browser. Used only by the backend worker.
SUPABASE_KEY=
# anon/public key — safe for browser clients. REQUIRED by serve.py (SEC-05).
# Find this in: Supabase Dashboard > Settings > API > Project API Keys > anon public
SUPABASE_ANON_KEY=

# === Dashboard Server ===
# SEC-01: Defaults to 127.0.0.1 (localhost only). Set to 0.0.0.0 only when
# running behind a reverse proxy (nginx/Caddy) with authentication in front of it.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8502
# AUTH-01: Comma-separated list of email addresses allowed to log in.
# Anyone not in this list is rejected even if they have a valid Supabase account.
ALLOWED_EMAILS=you@gmail.com,colleague@example.com

# === Alembic (direct PostgreSQL for migrations) ===
DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# === Ingestion ===
PLAYWRIGHT_ENABLED=false

# === LiteLLM Failover ===
GROQ_API_KEY=
FALLBACK_MODEL=llama-3.3-70b-versatile
LITELLM_FALLBACK_ENABLED=true

# === Redis Cache ===
# SEC-19: Default Redis URL has no authentication. In production, configure Redis with requirepass
# and use format: redis://:STRONG_PASSWORD@localhost:6379/0
REDIS_URL=redis://localhost:6379/0
LLM_CACHE_ENABLED=false
LLM_CACHE_TTL_SECONDS=86400

# === Langfuse Tracing ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Batch API ===
USE_BATCH_API=false
